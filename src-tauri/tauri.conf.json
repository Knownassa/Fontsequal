{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Fontsequal",
  "version": "0.1.0",
  "identifier": "app.fontsequal.desktop",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Fontsequal",
        "width": 1200,
        "height": 800,
        "minWidth": 960,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "appimage", "nsis", "msi"],
    "icon": ["icons/icon.png"],
    "windows": {
      "digestAlgorithm": "sha256"
    },
    "linux": {
      "deb": { "depends": ["fontconfig"] }
    }
  }
}
